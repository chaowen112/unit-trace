{
  "manifest_version": 3,
  "name": "UnitTrace",
  "version": "1.0.0",
  "description": "Track PropertyGuru listings — detect relists, price drops, and shared viewing history.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.propertyguru.com.sg/*",
    "https://unittrace.tet.sg/*"
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.propertyguru.com.sg/listing/*",
        "https://www.propertyguru.com.sg/property-listing/*"
      ],
      "js": ["content-listing.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.propertyguru.com.sg/property-for-sale*",
        "https://www.propertyguru.com.sg/property-for-rent*",
        "https://www.propertyguru.com.sg/residential/*",
        "https://www.propertyguru.com.sg/singapore-property-for-sale*",
        "https://www.propertyguru.com.sg/singapore-property-for-rent*",
        "https://www.propertyguru.com.sg/listing-search*"
      ],
      "js": ["content-search.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_title": "UnitTrace",
    "default_popup": "options.html"
  }
}
